# Copy this file to .env and fill in real values. NEVER commit .env.

ENV=development

# --- Database ---
DATABASE_PATH=database/app.db

# --- LLM: Google Gemini (primary, free tier) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- LLM fallback #1: Groq (free tier) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# --- LLM fallback #2: OpenRouter (free models) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# How many past turns to feed back to the LLM as context
CONTEXT_WINDOW_TURNS=10

# --- WhatsApp channel selector: "meta" or "twilio" ---
WHATSAPP_PROVIDER=meta

# --- Meta WhatsApp Cloud API (free test environment) ---
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=choose-any-random-string-here
META_APP_SECRET=
META_GRAPH_API_VERSION=v20.0

# --- Twilio WhatsApp Sandbox (fallback channel) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# --- Admin ---
ADMIN_API_KEY=change-me
